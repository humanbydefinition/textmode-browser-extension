{
	"name": "textmode-ascii-overlay-extension",
	"version": "1.0.0",
	"description": "Browser extension for overlaying real-time textmode.js ASCII conversion on page canvas and video elements.",
	"type": "module",
	"license": "MIT",
	"author": "humanbydefinition",
	"homepage": "https://code.textmode.art",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/humanbydefinition/textmode-browser-extensions.git"
	},
	"bugs": {
		"url": "https://github.com/humanbydefinition/textmode-browser-extensions/issues"
	},
	"keywords": [
		"ascii-art",
		"browser-extension",
		"chrome-extension",
		"creative-coding",
		"textmode",
		"textmode-js",
		"wxt"
	],
	"engines": {
		"node": ">=20.8.1"
	},
	"scripts": {
		"postinstall": "wxt prepare",
		"build": "wxt build",
		"build:chrome": "wxt build -b chrome --mv3",
		"build:e2e:chrome": "wxt build -b chrome --mv3 --mode e2e",
		"build:edge": "wxt build -b edge --mv3",
		"build:firefox": "wxt build -b firefox --mv3",
		"build:safari": "wxt build -b safari",
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox --mv3",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox --mv3",
		"lint:firefox": "npm run build:firefox && web-ext lint --source-dir .output/firefox-mv3 --self-hosted",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"format": "prettier --write .",
		"check:format": "prettier --check .",
		"check:boundaries": "node ./scripts/check-boundaries.mjs",
		"check": "npm run check:format && npm run lint && npm run check:boundaries && npm run typecheck && npm run test && npm run build:chrome && npm run lint:firefox",
		"e2e": "npm run build:e2e:chrome && playwright test"
	},
	"dependencies": {
		"textmode.export.js": "^1.5.1",
		"textmode.js": "0.17.0-beta.1"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"shell-quote": "1.8.4",
		"tmp": "0.2.7",
		"uuid": "11.1.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/chrome": "^0.2.0",
		"@types/node": "^26.0.0",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^10.5.0",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.9",
		"web-ext": "^10.4.0",
		"wxt": "^0.20.27"
	}
}
